# ─── Banco de Dados ───────────────────────────────────────
POSTGRES_USER=chatwoot
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
POSTGRES_DB=chatwoot

# ─── Redis ────────────────────────────────────────────────
REDIS_PASSWORD=TROQUE_POR_SENHA_FORTE

# ─── Chatwoot ─────────────────────────────────────────────
# Gere com: openssl rand -hex 64
SECRET_KEY_BASE=GERE_COM_OPENSSL_RAND_HEX_64

# URL pública do Chatwoot (ex: https://chatwoot.up.railway.app)
FRONTEND_URL=https://SEU_CHATWOOT.up.railway.app

# Conta padrão (deixe 1)
DEFAULT_LOCALE=pt_BR

# ─── Mailer (opcional – para notificações por e-mail) ─────
MAILER_SENDER_EMAIL=noreply@seudominio.com
# SMTP_ADDRESS=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=seu@gmail.com
# SMTP_PASSWORD=sua_senha_app

# ─── Evolution API ────────────────────────────────────────
# URL pública da Evolution API
EVOLUTION_API_URL=https://SEU_EVOLUTION.up.railway.app
# Chave mestre de autenticação (crie uma senha forte)
EVOLUTION_API_KEY=TROQUE_POR_CHAVE_FORTE

# ─── Módulo de Vendas ─────────────────────────────────────
# Gere com: openssl rand -hex 32
JWT_SECRET=GERE_COM_OPENSSL_RAND_HEX_32

# URL interna do Chatwoot para o módulo de vendas (em produção
# no Railway, use o URL interno do serviço)
CHATWOOT_URL=http://chatwoot-web:3001
